{
  "name": "jankx-woocommerce-extension",
  "version": "1.0.0",
  "description": "WooCommerce extension for Jankx theme",
  "scripts": {
    "build": "wp-scripts build blocks/buy-now-button/index.js blocks/sale-badge/index.js --output-path=blocks/buy-now-button/build && wp-scripts build blocks/sale-badge/index.js --output-path=blocks/sale-badge/build",
    "build:buy-now": "wp-scripts build blocks/buy-now-button/index.js --output-path=blocks/buy-now-button/build",
    "build:sale-badge": "wp-scripts build blocks/sale-badge/index.js --output-path=blocks/sale-badge/build",
    "start": "wp-scripts start",
    "check-engines": "wp-scripts check-engines",
    "lint:js": "wp-scripts lint-js",
    "lint:css": "wp-scripts lint-style",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@wordpress/scripts": "^26.0.0",
    "@wordpress/blocks": "^12.0.0",
    "@wordpress/block-editor": "^12.0.0",
    "@wordpress/components": "^25.0.0",
    "@wordpress/i18n": "^4.0.0",
    "@wordpress/element": "^5.0.0"
  },
  "stylelint": {
    "extends": "@wordpress/stylelint-config/scss"
  },
  "eslintConfig": {
    "extends": "@wordpress/eslint-plugin/recommended"
  }
}
